<Window x:Class="WpfApp1.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="525" Width="420" ResizeMode="NoResize">

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Регистрация" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <TextBlock Text="Логин"/>
            <TextBox x:Name="txtLogin" Height="35" Margin="0,5"/>
            <TextBlock Text="Почта"/>
            <TextBox x:Name="txtEmail" Height="35" Margin="0,5"/>
            <TextBlock Text="Имя"/>
            <TextBox x:Name="txtDisplayName" Height="35" Margin="0,5"/>
            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="txtPassword" Height="35" Margin="0,5"/>
            <Button Content="Зарегистрироваться" Click="BtnRegister_Click" Height="45" Margin="0,20,0,10"/>
            <Button Content="Отмена" Click="BtnCancel_Click" Height="40"/>
        </StackPanel>
    </Grid>
</Window>