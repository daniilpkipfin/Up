<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Читай, Пиши и не спиши" Height="720" Width="1250"
        Background="WhiteSmoke" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Минимальный стиль боковой кнопки с изображением -->
        <Style x:Key="SidebarImageButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- Боковая панель (светлая, минималистичная) -->
        <Border Width="72" Background="#F5F5F5" HorizontalAlignment="Left">
            <StackPanel Margin="8" VerticalAlignment="Top">
                <!-- Кнопки с изображениями (замените Source на фактические пути к вашим иконкам) -->
                <Button x:Name="btnCatalog" Style="{StaticResource SidebarImageButton}"
                        ToolTip="Каталог книг" Click="BtnCatalog_Click">
                    <Image Source="/Covers/Catalog.jpg" Width="24" Height="24"/>
                </Button>

                <Button x:Name="btnLists" Style="{StaticResource SidebarImageButton}"
                        ToolTip="Списки книг" Click="BtnLists_Click">
                    <Image Source="/Covers/Lists.jpg" Width="24" Height="24"/>
                </Button>

                <Button x:Name="btnAuthor" Style="{StaticResource SidebarImageButton}"
                        ToolTip="Страница автора" Click="BtnAuthor_Click"
                        Visibility="Collapsed">
                    <Image Source="/Covers/Author.jpg" Width="24" Height="24"/>
                </Button>

                <Button x:Name="btnAdmin" Style="{StaticResource SidebarImageButton}"
                        ToolTip="Администрирование" Click="BtnAdmin_Click"
                        Visibility="Collapsed">
                    <Image Source="/Covers/Admin.jpg" Width="24" Height="24"/>
                </Button>

                <Button Style="{StaticResource SidebarImageButton}"
                        ToolTip="Профиль" Click="BtnProfile_Click">
                    <Image Source="/Covers/Profile.jpg" Width="24" Height="24"/>
                </Button>
            </StackPanel>
        </Border>

        <ContentControl x:Name="ContentArea" Margin="72,0,0,0"/>
    </Grid>
</Window>