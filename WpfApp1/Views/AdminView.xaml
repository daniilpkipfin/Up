<UserControl x:Class="WpfApp1.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp1.Views"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Цветовая палитра -->
        <SolidColorBrush x:Key="AccentBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="White"/>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#777777"/>

        <!-- Стиль для плоской кнопки действия -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D2E3FC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ListView (чистый вид) -->
        <Style TargetType="ListView">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Стиль для заголовков столбцов GridView -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource LightBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- Стиль для строк ListViewItem (чередование и наведение) -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F4F8"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E8F0"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TextBlock статуса -->
        <Style x:Key="StatusTextBlock" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Стиль для вкладок TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6,6,0,0"
                                Margin="2,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" Background="{StaticResource WhiteBrush}">
        <TabControl>
            <!-- Вкладка Жалобы -->
            <TabItem Header="Жалобы">
                <ListView ItemsSource="{Binding Complaints}" x:Name="lvComplaints"
                          AlternationCount="2">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                            <GridViewColumn Header="Тип" DisplayMemberBinding="{Binding TargetType}" Width="80"/>
                            <GridViewColumn Header="Причина" DisplayMemberBinding="{Binding Reason}" Width="400"/>
                            <GridViewColumn Header="Действия" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Принять" 
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ApproveComplaint_Click" Tag="{Binding}"
                                                    Margin="0,0,5,0"/>
                                            <Button Content="Отклонить" 
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="RejectComplaint_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- Вкладка Заявки на роль Автора -->
            <TabItem Header="Заявки на роль Автора">
                <ListView ItemsSource="{Binding RoleRequests}" AlternationCount="2">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Пользователь" DisplayMemberBinding="{Binding Users.DisplayName}" Width="200"/>
                            <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="100"/>
                            <GridViewColumn Header="Действия" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Одобрить"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ApproveRoleRequest_Click" Tag="{Binding}"
                                                    Margin="0,0,5,0"/>
                                            <Button Content="Отклонить"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="RejectRoleRequest_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- Вкладка Заявки на разморозку -->
            <TabItem Header="Заявки на разморозку">
                <ListView ItemsSource="{Binding UnfreezeRequests}" AlternationCount="2">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Тип" Width="100"/>
                            <GridViewColumn Header="Причина" DisplayMemberBinding="{Binding Reason}" Width="400"/>
                            <GridViewColumn Header="Действия" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Разморозить"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ApproveUnfreeze_Click" Tag="{Binding}"
                                                    Margin="0,0,5,0"/>
                                            <Button Content="Отклонить"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="RejectUnfreeze_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- Вкладка Замороженные -->
            <TabItem Header="Замороженные">
                <ListView ItemsSource="{Binding FrozenItems}" AlternationCount="2">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Тип"
                                Width="140"
                                DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="Название"
                                Width="420"
                                DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Дата"
                                Width="160"
                                DisplayMemberBinding="{Binding FrozenDate, StringFormat=dd.MM.yyyy HH:mm}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- Вкладка Пользователи -->
            <TabItem Header="Пользователи">
                <ListView ItemsSource="{Binding Users}" AlternationCount="2">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Логин" DisplayMemberBinding="{Binding Login}" Width="120"/>
                            <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding DisplayName}" Width="200"/>
                            <GridViewColumn Header="Роль" DisplayMemberBinding="{Binding Roles.RoleName}" Width="100"/>
                            <GridViewColumn Header="Статус" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusTextBlock}">
                                                    <Setter Property="Text" Value="Активен"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFrozen}" Value="True">
                                                            <Setter Property="Text" Value="Заморожен"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- Колонка Действия (кнопки скрыты для администраторов) -->
                            <GridViewColumn Header="Действия" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Roles.RoleName}" Value="Admin">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Content="Сменить роль"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ChangeUserRole_Click" Tag="{Binding}"
                                                    Margin="0,0,5,0"/>
                                            <Button Content="Сменить пароль"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ChangePassword_Click" Tag="{Binding}"
                                                    Margin="0,0,5,0"/>
                                            <Button Content="Заморозить/Разморозить"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ToggleFreezeUser_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>