<UserControl x:Class="WpfApp1.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp1.Views"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Цветовая палитра -->
        <SolidColorBrush x:Key="AccentBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="White"/>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#777777"/>

        <!-- Основная кнопка (зелёная) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#219A52"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Опасная кнопка (красная) -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A93226"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Предупреждающая кнопка (оранжевая) -->
        <Style x:Key="WarningButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F39C12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E08E0B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C87F0A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Плоская кнопка (для второстепенных действий) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D2E3FC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стили для ListView -->
        <Style TargetType="ListView">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource LightBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F4F8"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E8F0"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: профиль -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                VerticalAlignment="Top"
                Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.08"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{Binding User.DisplayName}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding User.Email}"
                           FontSize="15"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Margin="0,0,0,5"/>

                <TextBlock Text="{Binding User.Roles.RoleName}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,15"/>

                <!-- Блок заморозки -->
                <Border Background="#FFE5E5"
                        Padding="12"
                        CornerRadius="8"
                        Visibility="{Binding FrozenVisibility}"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Аккаунт заморожен"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="#C62828"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding FreezeReason}"
                                   TextWrapping="Wrap"
                                   Foreground="#333"
                                   Margin="0,0,0,10"/>
                        <Button Content="Оспорить блокировку"
                                Width="180"
                                Height="32"
                                HorizontalAlignment="Left"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="AppealFreeze_Click"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки действий -->
                <Button Content="Подать заявку на роль автора"
                        Width="220"
                        Height="38"
                        Margin="0,0,0,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="RequestAuthor_Click"
                        Visibility="{Binding AuthorRequestVisibility}"/>

                <Button Content="Сменить пользователя"
                        Width="180"
                        Height="38"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="Unregistration_Click"/>
            </StackPanel>
        </Border>

        <!-- Правая колонка: отзывы -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Мои отзывы"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10"/>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding UserReviews}"
                          AlternationCount="2">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Книга"
                                            Width="220"
                                            DisplayMemberBinding="{Binding Books.Title}"/>
                            <GridViewColumn Header="Оценка"
                                            Width="80"
                                            DisplayMemberBinding="{Binding Rating}"/>
                            <GridViewColumn Header="Отзыв"
                                            Width="450"
                                            DisplayMemberBinding="{Binding ReviewText}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>