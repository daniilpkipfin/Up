<UserControl x:Class="WpfApp1.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp1.Views"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Цветовая палитра -->
        <SolidColorBrush x:Key="AccentBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="White"/>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#777777"/>

        <!-- Стиль для карточки книги (увеличен и с триггером на заморозку) -->
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="400"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect ShadowDepth="4" BlurRadius="10" Opacity="0.2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <!-- Синий фон, если книга заморожена -->
                <DataTrigger Binding="{Binding Book.IsFrozen}" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="BorderBrush" Value="#90CAF9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок в карточке -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D2E3FC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TextBox поиска -->
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="White"
                                                BorderBrush="#D0D0D0"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8,5">
                                            <Grid>
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,20,0"/>
                                                <Path x:Name="Arrow"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Fill="#666"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="#D0D0D0"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F4F8"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E8F0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон карточки книги -->
        <DataTemplate x:Key="BookCardTemplate">
            <Border Style="{StaticResource BookCardStyle}">
                <StackPanel>
                    <!-- Обложка (увеличена) -->
                    <Image Source="{Binding Book.CoverPath}" 
                           Width="150" Height="150" 
                           Stretch="UniformToFill"
                           Margin="0,0,0,10"/>
                    <!-- Название -->
                    <TextBlock Text="{Binding Title}" 
                               FontWeight="SemiBold" 
                               FontSize="14" 
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Title}"
                               Margin="0,0,0,4"/>
                    <!-- Автор -->
                    <TextBlock Text="{Binding DisplayName}" 
                               FontSize="12" 
                               Foreground="{StaticResource SubtleTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DisplayName}"
                               Margin="0,0,0,6"/>
                    <!-- Рейтинг -->
                    <TextBlock Text="{Binding AvgRating, StringFormat= Рейтинг {0:0.0}}" 
                               FontSize="13" 
                               FontWeight="SemiBold" 
                               Foreground="#F39C12"
                               Margin="0,0,0,10"/>
                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Открыть"
                                Style="{StaticResource CardButtonStyle}"
                                Click="OpenBook_Click"
                                Tag="{Binding Book}"/>
                        <Button Content="В список"
                                Style="{StaticResource CardButtonStyle}"
                                Click="AddToList_Click"
                                Tag="{Binding Book}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtSearch" 
                         Width="300" Height="35" 
                         Margin="0,0,10,0"
                         TextChanged="txtSearch_TextChanged"
                         ToolTip="Поиск по названию или автору"/>

                <ComboBox x:Name="cmbGenre" 
                          Width="200" Height="35" 
                          Margin="0,0,10,0"
                          SelectionChanged="cmbGenre_SelectionChanged">
                    <ComboBoxItem Content="Все жанры" IsSelected="True"/>
                </ComboBox>

                <ComboBox x:Name="cmbSort" 
                          Width="200" Height="35"
                          SelectionChanged="cmbSort_SelectionChanged">
                    <ComboBoxItem Content="По названию (А-Я)" IsSelected="True"/>
                    <ComboBoxItem Content="По названию (Я-А)"/>
                    <ComboBoxItem Content="По рейтингу (высокий)"/>
                    <ComboBoxItem Content="По рейтингу (низкий)"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Сетка книг -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource LightBackgroundBrush}">
            <ItemsControl ItemsSource="{Binding FilteredBooks}"
                          ItemTemplate="{StaticResource BookCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>